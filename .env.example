# Kalshi API (required)
KALSHI_API_KEY_ID=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY_PATH=your-kalshi-key.txt

# Anthropic API (required for AI debate)
ANTHROPIC_API_KEY=sk-ant-...

# FRED API (optional, for economic data)
FRED_API_KEY=your-fred-api-key

# Email notifications (optional, Gmail SMTP)
KALSHI_EMAIL_PASSWORD=your-gmail-app-password

# Polymarket (optional, for cross-platform trading)
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER=0x...

# Trading mode safety
# KALSHI_DRY_RUN=true           # Set to 'false' to enable live trading via env var
# KALSHI_CONFIRM_LIVE=false     # Set to '1' to suppress live-trading warning banner
# KALSHI_ENVIRONMENT=demo       # 'demo' or 'prod'

# Dashboard
# KALSHI_DASHBOARD_TOKEN=       # Optional auth token for dashboard API
